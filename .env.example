# Required for non-dry-run Codex execution.
OPENAI_API_KEY=

# Required by the Codex container entrypoint. Either set CODEX_TASK directly or
# point CODEX_TASK_FILE at a file inside the mounted repository workspace.
CODEX_TASK=
CODEX_TASK_FILE=

# Optional runtime controls.
CODEX_DRY_RUN=1
CODEX_WORKSPACE_DIR=/workspace
CODEX_MODEL=codex-mini-latest

# Optional override for the command executed inside the container. The default
# installs dependencies, then runs the Codex CLI from the repository root.
CODEX_COMMAND=
